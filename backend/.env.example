# ─── Local Development .env ───
# Copy this to backend/.env and adjust paths as needed.
# For Docker Compose, these are set via docker-compose.yml environment section.

# ─── Database ───
DATABASE_URL=postgresql://steel_user:steel_pass_change_me@localhost:5432/steel_defects

# ─── JWT ───
JWT_SECRET=replace-with-a-long-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Model ───
# Local path to the trained checkpoint (relative to backend dir OR absolute)
MODEL_PATH=../ai/checkpoints/best_model.pt

# ─── File Upload ───
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── Inference ───
DEFECT_CONFIDENCE_THRESHOLD=0.70

# ─── CORS (comma-separated list of allowed origins) ───
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
